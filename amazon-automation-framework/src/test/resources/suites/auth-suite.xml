<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!-- auth-suite.xml — Auth team only -->
<suite name="Auth Team Suite" parallel="methods" thread-count="3" verbose="1">
    <listeners>
        <listener class-name="com.amazon.framework.listeners.ExtentReportManager"/>
        <listener class-name="com.amazon.framework.listeners.RetryTransformer"/>
    </listeners>
    <test name="Login BDD">
        <parameter name="cucumber.filter.tags" value="@login"/>
        <classes><class name="com.amazon.runners.CucumberRunner"/></classes>
    </test>
</suite>
