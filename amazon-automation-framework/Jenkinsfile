// Jenkinsfile — Amazon Automation Framework
// Declarative pipeline with Grid lifecycle, parallel matrix, and reporting.
// ═══════════════════════════════════════════════════════════════════════════

pipeline {

    agent any

    // ─── Runtime parameters — set from Jenkins UI or API trigger ─────────────
    parameters {
        choice(
            name: 'SUITE',
            choices: ['suites/smoke-suite.xml', 'suites/regression-suite.xml',
                      'suites/checkout-suite.xml', 'suites/auth-suite.xml'],
            description: 'TestNG suite to run'
        )
        choice(
            name: 'BROWSER',
            choices: ['chrome', 'firefox', 'edge'],
            description: 'Browser for Grid execution'
        )
        choice(
            name: 'ENV',
            choices: ['staging', 'local'],
            description: 'Target environment'
        )
        string(
            name: 'TAGS',
            defaultValue: '@smoke',
            description: 'Cucumber tags filter (e.g. @smoke, @checkout, @p1)'
        )
        string(
            name: 'THREADS',
            defaultValue: '10',
            description: 'Parallel thread count'
        )
    }

    // ─── Triggers — GitHub push + scheduled runs ──────────────────────────────
    triggers {
        // Auto trigger on every GitHub push → uses smoke suite (default params)
        githubPush()

        // Every midnight 12 AM → smoke suite (default params)
        cron('H 0 * * *')

        // Every night 11 PM → regression suite (overrides params)
        parameterizedCron('''
            H 23 * * * % SUITE=suites/regression-suite.xml;BROWSER=chrome;ENV=staging;TAGS=@regression;THREADS=10
        ''')
    }

    // ─── Credentials injected as env vars — never hardcoded ──────────────────
    environment {
        TEST_EMAIL     = credentials('amazon-test-email')
        TEST_PASSWORD  = credentials('amazon-test-password')
        BS_USERNAME    = credentials('browserstack-username')
        BS_ACCESS_KEY  = credentials('browserstack-key')
        HUB_URL        = 'http://selenium-hub:4444/wd/hub'
        BUILD_NUMBER   = "${env.BUILD_NUMBER}"
        TEAMS_WEBHOOK  = credentials('teams-webhook-url')
    }

    stages {

        // ─── 1. Checkout code ─────────────────────────────────────────────────
        stage('Checkout') {
            steps {
                checkout scm
                echo "Branch: ${env.GIT_BRANCH} | Build: ${env.BUILD_NUMBER}"
            }
        }

        // ─── 2. Start Selenium Grid ───────────────────────────────────────────
        stage('Start Selenium Grid') {
            steps {
                dir('docker') {
                    sh '''
                        docker-compose -f docker-compose.yml -f docker-compose.ci.yml up -d
                        echo "Waiting for Grid to be healthy..."
                    '''
                }
                // Poll until Grid is ready — fail fast if it doesn't start
                timeout(time: 2, unit: 'MINUTES') {
                    waitUntil {
                        script {
                            def status = sh(
                                script: 'curl -sf http://localhost:4444/status | python3 -c "import sys,json; d=json.load(sys.stdin); print(d[\'value\'][\'ready\'])"',
                                returnStdout: true
                            ).trim()
                            return status == 'True'
                        }
                    }
                }
                echo "Selenium Grid is ready"
            }
        }

        // ─── 3. Parallel test execution ───────────────────────────────────────
        stage('Run Tests in Parallel') {
            parallel {

                stage('Chrome Tests') {
                    steps {
                        sh """
                            mvn test \
                              -Denv=${params.ENV} \
                              -Dbrowser=chrome \
                              -Dsuite=${params.SUITE} \
                              -Dheadless=true \
                              -Dhub.url=${HUB_URL} \
                              -Dthreads=${params.THREADS} \
                              -Dcucumber.filter.tags="${params.TAGS}" \
                              -DTEST_EMAIL="${TEST_EMAIL}" \
                              -DTEST_PASSWORD="${TEST_PASSWORD}" \
                              -Dsurefire.failIfNoSpecifiedTests=false
                        """
                    }
                    post {
                        always {
                            junit allowEmptyResults: true,
                                  testResults: 'target/surefire-reports/*.xml'
                        }
                    }
                }

                stage('Firefox Tests') {
                    when { expression { params.SUITE.contains('regression') } }
                    steps {
                        sh """
                            mvn test \
                              -Denv=${params.ENV} \
                              -Dbrowser=firefox \
                              -Dsuite=suites/smoke-suite.xml \
                              -Dheadless=true \
                              -Dhub.url=${HUB_URL} \
                              -Dthreads=5 \
                              -Dcucumber.filter.tags="@smoke and @p1" \
                              -DTEST_EMAIL="${TEST_EMAIL}" \
                              -DTEST_PASSWORD="${TEST_PASSWORD}"
                        """
                    }
                }
            }
        }

        // ─── 4. Cross-browser on BrowserStack (main branch only) ─────────────
        stage('BrowserStack Cross-Browser') {
            when {
                allOf {
                    branch 'main'
                    expression { params.SUITE.contains('regression') }
                }
            }
            steps {
                sh """
                    mvn test \
                      -Denv=cloud \
                      -Dbrowser=safari \
                      -Dsuite=suites/smoke-suite.xml \
                      -Dcucumber.filter.tags="@smoke and @p1" \
                      -DTEST_EMAIL="${TEST_EMAIL}" \
                      -DTEST_PASSWORD="${TEST_PASSWORD}"
                """
            }
        }

        // ─── 5. Publish reports ───────────────────────────────────────────────
        stage('Publish Reports') {
            steps {
                // Extent HTML report
                publishHTML(target: [
                    allowMissing:          true,
                    alwaysLinkToLastBuild: true,
                    keepAll:               true,
                    reportDir:             'target/extent-reports',
                    reportFiles:           'AmazonTestReport.html',
                    reportName:            'Extent Test Report'
                ])

                // Cucumber HTML report
                publishHTML(target: [
                    allowMissing:  true,
                    reportDir:     'target/cucumber-reports',
                    reportFiles:   'report.html',
                    reportName:    'Cucumber Report'
                ])
            }
        }
    }

    post {
        always {
            // Tear down Grid — always runs even if tests fail
            dir('docker') {
                sh 'docker-compose down || true'
            }

            // Archive screenshots, logs, and reports as artifacts
            archiveArtifacts artifacts: 'target/screenshots/**/*.png',
                             allowEmptyArchive: true
            archiveArtifacts artifacts: 'target/logs/**/*.log',
                             allowEmptyArchive: true
            archiveArtifacts artifacts: 'target/extent-reports/**',
                             allowEmptyArchive: true

            cleanWs()
        }

        success {
            // ─── Microsoft Teams notification ─────────────────────────────────
            office365ConnectorSend(
                webhookUrl: "${TEAMS_WEBHOOK}",
                message: "✅ BUILD PASSED | Suite: ${params.SUITE} | Env: ${params.ENV} | Browser: ${params.BROWSER} | Build: #${env.BUILD_NUMBER}",
                status: 'Success',
                color: '00FF00'
            )

            // ─── Email notification ───────────────────────────────────────────
            emailext(
                subject: "✅ Amazon Automation Passed - Build #${env.BUILD_NUMBER}",
                body: """
                    <h2>Build Passed ✅</h2>
                    <p><b>Suite:</b> ${params.SUITE}</p>
                    <p><b>Browser:</b> ${params.BROWSER}</p>
                    <p><b>Environment:</b> ${params.ENV}</p>
                    <p><b>Tags:</b> ${params.TAGS}</p>
                    <p><b>Threads:</b> ${params.THREADS}</p>
                    <p><b>Branch:</b> ${env.GIT_BRANCH}</p>
                    <p><b>Build URL:</b> <a href="${env.BUILD_URL}">${env.BUILD_URL}</a></p>
                """,
                mimeType: 'text/html',
                to: 'shananth82@gmail.com'
            )
        }

        failure {
            // ─── Microsoft Teams alert ────────────────────────────────────────
            office365ConnectorSend(
                webhookUrl: "${TEAMS_WEBHOOK}",
                message: "❌ BUILD FAILED | Suite: ${params.SUITE} | Env: ${params.ENV} | Browser: ${params.BROWSER} | Build: #${env.BUILD_NUMBER}",
                status: 'Failure',
                color: 'FF0000'
            )

            // ─── Email alert ──────────────────────────────────────────────────
            emailext(
                subject: "❌ Amazon Automation FAILED - Build #${env.BUILD_NUMBER}",
                body: """
                    <h2>Build Failed ❌</h2>
                    <p><b>Suite:</b> ${params.SUITE}</p>
                    <p><b>Browser:</b> ${params.BROWSER}</p>
                    <p><b>Environment:</b> ${params.ENV}</p>
                    <p><b>Tags:</b> ${params.TAGS}</p>
                    <p><b>Threads:</b> ${params.THREADS}</p>
                    <p><b>Branch:</b> ${env.GIT_BRANCH}</p>
                    <p><b>Build URL:</b> <a href="${env.BUILD_URL}">${env.BUILD_URL}</a></p>
                    <p>Please check the logs for details.</p>
                """,
                mimeType: 'text/html',
                to: 'shananth82@gmail.com'
            )
        }
    }
}
